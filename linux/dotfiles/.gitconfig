[user]
	name = Russell Bunch
	email = rusty@4lambda.io
#	signingkey =

[push]
	default = simple

[core]
	autocrlf = input
	editor = vim
	excludesfile = /home/rusty/.gitignore

[commit]
#    gpgsign = true

[alias]
	r = !GIT_NO_PAGER=1 git l -30
	l = "!. ~/.githelpers && pretty_git_log"
[color]
	ui = auto

[color "branch"]
	current = yellow
	local = 241
	remote = green

[color "diff"]
	meta = yellow
	frag = magenta
	old = red
	new = green

[color "status"]
	added = green
	changed = yellow
	untracked = magenta
[advice]
 	detachedHead = false
[tag]
# Note: gpgSign on tags forces annotated tags
#	gpgSign = true
