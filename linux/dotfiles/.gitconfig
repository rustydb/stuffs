[user]
	name = Russell Bunch
	email = rusty@4lambda.io
    signingKey = 232CA927AC960625

[commit]
	template = ~/.stCommitMsg
	gpgsign = true

[includeIf "gitdir:~/gitstuffs/work/"]
    path = ~/.gitconfig-hpe

[push]
	default = simple
	autoSetupRemote = true

[core]
	autocrlf = input
	editor = vim
	excludesfile = ~/.gitignore

[alias]
	r = !GIT_NO_PAGER=1 git l -30
	l = "!. ~/.githelpers && pretty_git_log"

[color]
	ui = auto

[color "branch"]
	current = yellow
	local = 241
	remote = green

[color "diff"]
	meta = yellow
	frag = magenta
	old = red
	new = green

[color "status"]
	added = green
	changed = yellow
	untracked = magenta

[advice]
	detachedHead = false
